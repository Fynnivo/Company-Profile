RewriteEngine On
RewriteBase /company_profile/

# Block direct access to admin includes and config
RewriteRule ^admin/includes/ - [F,L]
RewriteRule ^config/ - [F,L]

# Clean URL: /artikel/{slug} → artikel-detail.php?slug={slug}
RewriteRule ^artikel/([a-z0-9\-]+)/?$ artikel-detail.php?slug=$1 [L,QSA]

# Clean URL: /layanan/{slug} → layanan-detail.php?slug={slug}
RewriteRule ^layanan/([a-z0-9\-]+)/?$ layanan-detail.php?slug=$1 [L,QSA]

# Remove .php extension from URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/?$ $1.php [L,QSA]

# Redirect trailing slashes
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]
